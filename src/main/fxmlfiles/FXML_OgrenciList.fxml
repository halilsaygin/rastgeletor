         <children>
            <ImageView fx:id="imageview_home" fitHeight="45.0" fitWidth="46.0" layoutX="11.0" layoutY="357.0" onMouseClicked="#anaSahneAc" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../res/home.png" />
               </image>
            </ImageView>
            <TextField fx:id="txtf_ad_soyad" layoutX="11.0" layoutY="44.0" prefHeight="25.0" prefWidth="249.0" promptText="Öğrenci Ad Soyad" />
            <Button fx:id="btn_ogrenci_ekle" layoutX="83.0" layoutY="124.0" mnemonicParsing="false" onAction="#ekle_ogrenci" prefHeight="41.0" prefWidth="67.0" style="-fx-background-color: white;" styleClass="button-onceki-sonraki" stylesheets="@../ui_styles.css" text="EKLE">
