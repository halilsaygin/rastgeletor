<AnchorPane id="AnchorPane" prefHeight="412.0" prefWidth="612.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.controllers.FXML_OgrenciListController">
   <children>
      <Pane fx:id="pn_sinif_liste" layoutX="-14.0" prefHeight="412.0" prefWidth="612.0" style="-fx-background-color: #fef5e7;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <opaqueInsets>
